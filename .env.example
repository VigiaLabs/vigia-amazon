# Environment Variables (Copy to .env.local and fill in values)

# ─── AWS Configuration ────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=

# ─── Bedrock Agent ───────────────────────────────────────────────────────────
# Set as NEXT_PUBLIC_ so they are available in both server routes and the browser bundle.
NEXT_PUBLIC_BEDROCK_AGENT_ID=
NEXT_PUBLIC_BEDROCK_AGENT_ALIAS_ID=
NEXT_PUBLIC_AWS_REGION=us-east-1

# ─── API Gateway ─────────────────────────────────────────────────────────────
# Base URL for your deployed API Gateway stage (no trailing slash)
# e.g. https://abc123.execute-api.us-east-1.amazonaws.com/prod
NEXT_PUBLIC_API_URL=

# Separate telemetry endpoint if different from API_URL (optional, falls back to NEXT_PUBLIC_API_URL)
NEXT_PUBLIC_TELEMETRY_API_URL=

# ─── Amazon Location Service ─────────────────────────────────────────────────
# API key from Amazon Location Console (Maps > API keys)
NEXT_PUBLIC_LOCATION_API_KEY=

# Map resource names from your Amazon Location Service console
NEXT_PUBLIC_MAP_NAME=
NEXT_PUBLIC_MAP_NAME_SATELLITE=
NEXT_PUBLIC_MAP_NAME_TERRAIN=

# Route calculator resource name
NEXT_PUBLIC_ROUTE_CALCULATOR_NAME=

# ─── DynamoDB Tables ─────────────────────────────────────────────────────────
HAZARDS_TABLE_NAME=
COOLDOWN_TABLE_NAME=
TRACES_TABLE_NAME=
LEDGER_TABLE_NAME=

# ─── Secrets Manager ─────────────────────────────────────────────────────────
PUBLIC_KEY_SECRET_ARN=

# ─── Feature Flags ───────────────────────────────────────────────────────────
COST_LIMIT_FLAG=false
