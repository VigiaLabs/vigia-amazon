{
  "name": "vigia-amazon",
  "version": "1.0.0",
  "private": true,
  "description": "VIGIA: Sentient Road Infrastructure System",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@vigia/frontend",
    "build": "npm run build --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run test --workspaces",
    "cdk:synth": "npm run synth --workspace=@vigia/infrastructure",
    "cdk:deploy": "npm run deploy --workspace=@vigia/infrastructure"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "ngeohash": "^0.6.3"
  }
}
